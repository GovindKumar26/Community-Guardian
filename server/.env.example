# Environment Variables for Community Guardian
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/community-guardian

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Encryption Key for Safe Circles (32 hex bytes = 64 chars)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
